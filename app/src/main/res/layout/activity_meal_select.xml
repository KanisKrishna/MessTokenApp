<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Meal"
        android:textSize="22sp"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnBreakfast" android:text="Breakfast"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnLunch" android:text="Lunch"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnSnacks" android:text="Snacks"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnDinner" android:text="Dinner"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>