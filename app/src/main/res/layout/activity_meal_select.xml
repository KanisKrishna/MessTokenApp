<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Meal"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/colorOnSurface"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:tint="?attr/colorPrimary"
                android:src="@drawable/ic_food_pro" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What would you like to have today?"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="32dp"/>

            <!-- Breakfast Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">
                <TextView
                    android:id="@+id/btnBreakfast"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Breakfast"
                    android:textSize="22sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lunch Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">
                <TextView
                    android:id="@+id/btnLunch"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Lunch"
                    android:textSize="22sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Snacks Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">
                <TextView
                    android:id="@+id/btnSnacks"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Snacks"
                    android:textSize="22sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dinner Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">
                <TextView
                    android:id="@+id/btnDinner"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Dinner"
                    android:textSize="22sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>